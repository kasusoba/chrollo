DISCORD_TOKEN=xxx
DISCORD_CLIENT_ID=xxx
DISCORD_GUILD_ID=xxx
# Your Discord user ID — bot DMs this account if Google auth is dead on boot
DISCORD_OWNER_ID=xxx
# Port for the OAuth callback server (host + container). Must match the port in GOOGLE_REDIRECT_URI
PORT=5000
GOOGLE_CLIENT_ID=xxx-xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
GOOGLE_REDIRECT_URI=http://xxx/oauth2callback
SESSION_SECRET=xxx
